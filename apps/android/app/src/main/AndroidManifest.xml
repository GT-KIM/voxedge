<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Offline device tools (set_timer / set_alarm) hand off to the system clock app. -->
    <uses-permission android:name="com.android.alarm.permission.SET_ALARM" />

    <!-- Android 11+ package visibility: the intent-based tools (dial_number, send_sms, navigate,
         create_calendar_event) launch other apps via implicit intents. Without these <queries>
         entries the launches can fail on API 30+ even though a handler app exists. No dangerous
         permission is involved — each opens the target app pre-filled for the user to confirm. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <intent>
            <action android:name="android.intent.action.INSERT" />
            <data android:mimeType="vnd.android.cursor.dir/event" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:label="Conversational AI"
        android:supportsRtl="true"
        android:theme="@style/Theme.ConversationalAi">

        <!-- CDSP FastRPC for the HTP/DSP. Android 12+ (targetSDK 31+) requires an explicit
             request for vendor public native libraries; public.libraries listing alone is not
             enough. Without this the app process cannot complete the HTP FastRPC probe. -->
        <uses-native-library android:name="libcdsprpc.so" android:required="false" />
        <!-- OpenCL for the LiteRT-LM GPU backend (same API-31+ vendor-library rule as above). -->
        <uses-native-library android:name="libOpenCL.so" android:required="false" />
        <uses-native-library android:name="libOpenCL-pixel.so" android:required="false" />
        <uses-native-library android:name="libOpenCL-car.so" android:required="false" />

        <!-- singleTop so repeated adb "am start" debug_typed_turn invocations reach the SAME
             resident instance via onNewIntent (headless turn driving without reloading the
             engines or stacking duplicate LLM/TTS residents). -->
        <activity
            android:name=".ui.MainActivity"
            android:launchMode="singleTop"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Always-listening speech loop runs in a microphone foreground service. -->
        <service
            android:name=".core.ConversationService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

    </application>
</manifest>
