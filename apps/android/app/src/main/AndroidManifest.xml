<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:label="Conversational AI"
        android:supportsRtl="true"
        android:theme="@style/Theme.ConversationalAi">

        <!-- CDSP FastRPC for the HTP/DSP. Android 12+ (targetSDK 31+) requires an explicit
             request for vendor public native libraries; public.libraries listing alone is not
             enough. Without this the app process cannot complete the HTP FastRPC probe. -->
        <uses-native-library android:name="libcdsprpc.so" android:required="false" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Always-listening speech loop runs in a microphone foreground service. -->
        <service
            android:name=".core.ConversationService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

    </application>
</manifest>
